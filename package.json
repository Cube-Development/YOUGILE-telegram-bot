{
  "dependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lru-cache": "^11.3.6",
    "pino": "^10.3.1",
    "telegraf": "^4.16.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "codegen": "npx tsx src/scripts/generate-api.ts",
    "dev": "nodemon --watch src --ext ts --exec tsx src/index.ts",
    "format": "prettier --write \"src/**/*.{js,ts}\"",
    "lint": "eslint . --fix",
    "start": "tsx src/index.ts",
    "test": "vitest run"
  }
}
